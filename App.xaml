<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="flow_desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:flow_desktop">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->

            <!-- colors -->
            <Color x:Key="ColorKDB">#030303</Color>
            <Color x:Key="ColorSane">#111111</Color>
            <Color x:Key="ColorAguero">#181818</Color>
            <Color x:Key="ColorTelli">#FFFFFF</Color>
            <Color x:Key="ColorMarcelo">#3C3C3C</Color>
            <Color x:Key="ColorIsco">#4D4D4D</Color>
            <Color x:Key="ColorRaze">#68B439</Color>
            <Color x:Key="ColorDebit">#FD5273</Color>

            <!-- brushes -->
            <SolidColorBrush x:Key="BrushKDB" Color="{StaticResource ColorKDB}"/>
            <SolidColorBrush x:Key="BrushSane" Color="{StaticResource ColorSane}"/>
            <SolidColorBrush x:Key="BrushAguero" Color="{StaticResource ColorAguero}"/>
            <SolidColorBrush x:Key="BrushTelli" Color="{StaticResource ColorTelli}"/>
            <SolidColorBrush x:Key="BrushMarcelo" Color="{StaticResource ColorMarcelo}"/>
            <SolidColorBrush x:Key="BrushIsco" Color="{StaticResource ColorIsco}"/>
            <SolidColorBrush x:Key="BrushRaze" Color="{StaticResource ColorRaze}"/>
            <SolidColorBrush x:Key="BrushDebit" Color="{StaticResource ColorDebit}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
