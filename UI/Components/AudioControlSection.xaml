<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="flow_desktop.UI.Components.AudioControlSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:flow_desktop.UI.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        Width="{StaticResource AudioControlSectionWidth}"
        >
        <components:SeekBar 
            SeekBarWidth="{StaticResource AudioControlSectionWidth}"
            PlayProgress="{x:Bind PlayProgress, Mode=OneWay}"
            />
        <Border Width="32" />
        <components:AudioControlButtons 
            ContainerWidth="{StaticResource AudioControlSectionWidth}"
            IsPlaying="{x:Bind IsPlaying, Mode=OneWay}"
            OnPlayLoadedSong="HandlePlayLoadedSong"
            OnPause="HandlePause"
            />
    </StackPanel>
</UserControl>
