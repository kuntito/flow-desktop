<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="flow_desktop.UI.Components.PlayPauseButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:flow_desktop.UI.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="IconSize">24</x:Double>
        <x:Double x:Key="RippleSize">60</x:Double>
        <CornerRadius x:Key="ButtonCornerRadius">30</CornerRadius>
    </UserControl.Resources>

    <Button
        Background="Transparent"
        Click="OnClick"
        Padding="0"
        Width="{StaticResource RippleSize}"
        Height="{StaticResource RippleSize}"
        CornerRadius="{StaticResource ButtonCornerRadius}"
        BorderThickness="0"
    >
        <Image x:Name="PlayPauseIcon"
               Width="{StaticResource IconSize}"
               Height="{StaticResource IconSize}"
               />

    </Button>
</UserControl>
